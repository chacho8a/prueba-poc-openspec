# ===========================================
# Task Manager - Variables de Entorno
# ===========================================
# Copia este archivo a .env y ajusta los valores
# Comando: make env-setup
# ===========================================

# Clave secreta para firmar tokens JWT
# IMPORTANTE: Cambia este valor en producción (mínimo 32 caracteres)
SECRET_KEY=change-this-secret-key-in-production-min-32-chars

# URL de conexión a la base de datos
# SQLite (por defecto): sqlite:///./database/tasks.db
# PostgreSQL: postgresql://user:password@host:5432/dbname
DATABASE_URL=sqlite:///./database/tasks.db

# Algoritmo de encriptación para JWT
ALGORITHM=HS256

# Tiempo de expiración del token de acceso (en minutos)
ACCESS_TOKEN_EXPIRE_MINUTES=30
